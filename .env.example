# Required
ANTHROPIC_API_KEY=sk-ant-...

# Lemon Squeezy (lemonsqueezy.com — Gumroad alternative with real API)
# API key: app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
# Store ID (optional — auto-detected if you only have one store)
LEMONSQUEEZY_STORE_ID=

# Optional: for web search via SerpAPI (free tier available)
SERPAPI_KEY=

# Database path
DB_PATH=./data/agent.db

# Agent config
GOAL_AMOUNT=20000
GOAL_DAYS=60
START_DATE=2026-03-24
MODEL=claude-opus-4-6

# How often orchestrator runs (minutes)
SCAN_INTERVAL=30
EXECUTE_INTERVAL=60
